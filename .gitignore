# Reference materials (large standards docs, not needed in the repo)
reference/

# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/

# Environment variables / secrets
.env
.env.*
!.env.example

# Test / coverage
.coverage
.coverage.*
htmlcov/
coverage.xml

# IDE / editor
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# TLS / JWS keys and certs — never commit
*.pem
*.key
*.crt
*.p12
